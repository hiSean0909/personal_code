# ============================================================
# 复制本文件为 .env 后填入真实值
# 注意：.env 一定不要提交到 Git，建议加入 .gitignore
# ============================================================

# 【必填】DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 【可选】默认即可，企业私有部署才改
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 【可选】宿主机暴露端口，默认 7860
WEB_PORT=7860

# 【可选】Nginx 反代子路径，如 /translator；不用就留空
WEB_ROOT_PATH=
